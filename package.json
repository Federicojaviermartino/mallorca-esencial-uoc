{
  "name": "mallorca-esencial",
  "version": "1.0.0",
  "private": true,
  "description": "Mallorca Esencial - Valldemossa, Soller y Palma",
  "scripts": {
    "parcel:serve": "parcel -p 8123 --target web",
    "parcel:build": "parcel build --target web --no-source-maps --no-cache",
    "clean": "rimraf dist .cache .cache-loader .parcel-cache",
    "dev": "npm-run-all clean parcel:serve",
    "stylelint": "stylelint src/**/*.scss",
    "build": "npm-run-all clean stylelint parcel:build",
    "test": "echo 'Everything is working as expected ✅\nStart working on your project by running \\033[1mnpm run dev\\033[0m'"
  },
  "targets": {
    "web": {
      "context": "browser",
      "publicUrl": "./",
      "source": "src/index.html",
      "engines": {
        "browsers": "last 2 versions, > 0.5%, not dead"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Federicojaviermartino/mallorca-esencial-uoc.git"
  },
  "author": {
    "name": "Federico Javier Martino"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Federicojaviermartino/mallorca-esencial-uoc/issues"
  },
  "homepage": "https://github.com/Federicojaviermartino/mallorca-esencial-uoc#readme",
  "devDependencies": {
    "@parcel/transformer-sass": "^2.16.3",
    "autoprefixer": "^10.4.24",
    "npm-run-all": "^4.1.5",
    "parcel": "^2.16.3",
    "postcss-preset-env": "^11.1.2",
    "posthtml-include": "^2.0.1",
    "rimraf": "^6.1.2",
    "sharp": "^0.33.5",
    "stylelint": "^17.4.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-scss": "^7.0.0"
  },
  "dependencies": {
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/source-sans-pro": "^5.2.5",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "leaflet": "^1.9.4"
  }
}
